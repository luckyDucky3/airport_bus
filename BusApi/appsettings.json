{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=55432;Database=airport_bus;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "Enabled": true,
    "BootstrapServers": "localhost:9092",
    "HandlingTopic": "handling.events",
    "SimTopic": "sim.events",
    "BoardTopic": "board.events",
    "GroupId": "bus-service"
  },
  "Dependencies": {
    "Passengers": {
      "BaseUrl": "http://passengers:8000"
    },
    "Ground": {
      "BaseUrl": "http://ground:8000",
      "RouteTtlMinutes": 10
    }
  },
  "AllowedHosts": "*"
}
